class ProductAdmin(ModelView):
    column_list = ['id', 'name', 'brand', 'color', 'real_rub', 'price_rub', 'profit_rub', 'available']
    form_columns = ['name', 'description', 'price', 'brand', 'color', 'sizes', 'available', 'image']
    column_searchable_list = ['name', 'brand']
    form_choices = {'brand': [(b, b) for b in BRANDS], 'color': [(k, v) for k, v in COLORS.items()]}

    def real_rub(view, context, model, name):
        if not model.last_krw_price or model.last_krw_price < 10000: return '-'
        return f"{round((model.last_krw_price / USD_TO_KRW * USD_TO_RUB) / 10) * 10:,} ₽"

    def price_rub(view, context, model, name):
        if not model.last_krw_price or model.last_krw_price < 10000: return '-'
        return f"{round((model.last_krw_price / USD_TO_KRW * USD_TO_RUB * MARKUP) / 10) * 10:,} ₽"

    def profit_rub(view, context, model, name):
        if not model.last_krw_price or model.last_krw_price < 10000: return '-'
        real = round((model.last_krw_price / USD_TO_KRW * USD_TO_RUB) / 10) * 10
        with_m = round((model.last_krw_price / USD_TO_KRW * USD_TO_RUB * MARKUP) / 10) * 10
        return f"{with_m - real:,} ₽"

    column_formatters = {'real_rub': real_rub, 'price_rub': price_rub, 'profit_rub': profit_rub}

    def is_accessible(self):
        return current_user.is_authenticated


