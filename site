def get_sizes_list(sizes_str):
    if not sizes_str:
        return []
    return [s.strip() for s in sizes_str.split(',') if s.strip()]


def add_missing_columns():
    with app.app_context():
        inspector = db.inspect(db.engine)
        cols = [c['name'] for c in inspector.get_columns('product')]
        if 'last_krw_price' not in cols:
            db.engine.execute("ALTER TABLE product ADD COLUMN last_krw_price FLOAT DEFAULT 0")
        if 'markup_krw' not in cols:
            db.engine.execute("ALTER TABLE product ADD COLUMN markup_krw FLOAT DEFAULT 0")


