# ================== ПАРСЕР И КУРСЫ ==================
def get_random_headers():
    ua_list = [
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36",
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:136.0) Gecko/20100101 Firefox/136.0"
    ]
    return {"User-Agent": random.choice(ua_list), "Referer": "https://kream.co.kr/"}


def update_exchange_rates():
    global USD_TO_KRW, USD_TO_RUB
    try:
        r = requests.get("https://api.exchangerate-api.com/v4/latest/USD", timeout=10)
        if r.status_code == 200:
            data = r.json()['rates']
            USD_TO_KRW = data.get('KRW', USD_TO_KRW)
            USD_TO_RUB = data.get('RUB', USD_TO_RUB)
            print(f"✅ Курс обновлён: 1 USD = {USD_TO_KRW:.0f} KRW | {USD_TO_RUB:.2f} RUB")
    except Exception as e:
        print("⚠️ Не удалось обновить курс:", e)


def parse_kream_price(url):
    if not url or "kream.co.kr/products/" not in url: return None
    for attempt in range(1, 4):
        try:
            time.sleep(random.uniform(1.3, 2.8))
            r = requests.get(url, headers=get_random_headers(), timeout=8)
            if r.status_code != 200: continue
            text_lower = r.text.lower()
            candidates = []
            patterns = [r'"lowestprice"\s*:\s*(\d+)', r'"price"\s*:\s*(\d+)', r'"buyprice"\s*:\s*(\d+)']
            for pat in patterns:
                for m in re.findall(pat, text_lower):
                    p = int(m)
                    if 10000 <= p <= 5000000: candidates.append(p)
            for tag in re.findall(r'<h[1-3][^>]*>(.*?)</h[1-3]>', r.text, re.DOTALL | re.IGNORECASE):
                for m in re.findall(r'(\d{1,3}(?:[,\s]\d{3})*)\s*원', tag):
                    clean = re.sub(r'[^0-9]', '', m)
                    if clean:
                        p = int(clean)
                        if 10000 <= p <= 5000000: candidates.append(p)
            if candidates:
                return min(candidates)
        except:
            pass
    return None


def get_display_price(product):
    krw = getattr(product, 'last_krw_price', 0) or 0
    if krw < 10000: return None
    rub = round((krw / USD_TO_KRW * USD_TO_RUB * MARKUP) / 10) * 10
    usd = round(rub / USD_TO_RUB)
    return {"rub": int(rub), "usd": int(usd)}


def calculate_order_prices(krw):
    if not krw or krw < 10000: return None, None, None, None, None
    real_rub = round((krw / USD_TO_KRW * USD_TO_RUB) / 10) * 10
    real_usd = round(real_rub / USD_TO_RUB)
    price_rub = round((krw / USD_TO_KRW * USD_TO_RUB * MARKUP) / 10) * 10
    price_usd = round(price_rub / USD_TO_RUB)
    profit = price_rub - real_rub
    return price_rub, price_usd, real_rub, real_usd, profit


# ================== МОДЕЛИ БД ==================
class User(UserMixin, db.Model):
    id = db.Column(db.Integer, primary_key=True)
    username = db.Column(db.String(80), unique=True, nullable=False)
    password_hash = db.Column(db.String(256), nullable=False)

    def set_password(self, password): self.password_hash = generate_password_hash(password)

    def check_password(self, password): return check_password_hash(self.password_hash, password)


class Product(db.Model):
    id = db.Column(db.Integer, primary_key=True)
    name = db.Column(db.String(150), nullable=False)
    description = db.Column(db.Text)
    price = db.Column(db.String(300), nullable=False)
    sizes = db.Column(db.String(100))
    color = db.Column(db.String(20))
    brand = db.Column(db.String(50))
    available = db.Column(db.Boolean, default=True)
    image = db.Column(db.String(500))
    last_krw_price = db.Column(db.Float, default=0.0)
    markup_krw = db.Column(db.Float, default=0.0)


class Order(db.Model):
    id = db.Column(db.Integer, primary_key=True)
    name = db.Column(db.String(100), nullable=False)
    surname = db.Column(db.String(100), nullable=False)
    phone = db.Column(db.String(20), nullable=False)
    email = db.Column(db.String(100))
    address = db.Column(db.String(200), nullable=False)
    product_id = db.Column(db.Integer, db.ForeignKey('product.id'))
    size = db.Column(db.String(10))
    comment = db.Column(db.Text)
    date = db.Column(db.DateTime, default=datetime.utcnow)

    price_rub_at_order = db.Column(db.Float)
    price_usd_at_order = db.Column(db.Float)
    real_price_rub_at_order = db.Column(db.Float)
    real_price_usd_at_order = db.Column(db.Float)
    profit_rub = db.Column(db.Float)
    product = db.relationship('Product', backref='orders')


@login_manager.user_loader
def load_user(user_id): return User.query.get(int(user_id))


def get_sizes_list(sizes_str):
    if not sizes_str: return []
    return [s.strip() for s in sizes_str.split(',') if s.strip()]


def add_missing_columns():
    with app.app_context():
        inspector = db.inspect(db.engine)
        cols = [c['name'] for c in inspector.get_columns('product')]
        if 'color' not in cols: db.session.execute(text("ALTER TABLE product ADD COLUMN color VARCHAR(20)"))
        if 'brand' not in cols: db.session.execute(text("ALTER TABLE product ADD COLUMN brand VARCHAR(50)"))
        cols_order = [c['name'] for c in inspector.get_columns('order')]
        for col in ['price_rub_at_order', 'price_usd_at_order', 'real_price_rub_at_order', 'real_price_usd_at_order',
                    'profit_rub']:
            if col not in cols_order: db.session.execute(text(f"ALTER TABLE 'order' ADD COLUMN {col} FLOAT"))
        db.session.commit()


