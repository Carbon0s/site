@app.route('/order', methods=['GET', 'POST'])
def make_order():
    if request.method == 'POST':
        try:
            order = Order(
                name=request.form['name'],
                surname=request.form['surname'],
                phone=request.form['phone'],
                email=request.form.get('email'),
                address=request.form['address'],
                product_id=int(request.form['product_id']),
                size=request.form['size'],
                comment=request.form.get('comment')
            )
            db.session.add(order)
            db.session.commit()
            flash('Заказ успешно отправлен!', 'success')
            return redirect(url_for('thanks'))
        except:
            flash('Ошибка при создании заказа', 'danger')
            db.session.rollback()

    product_id = request.args.get('product_id')
    if not product_id:
        flash('Выберите товар', 'warning')
        return redirect('/')
    product = Product.query.get_or_404(int(product_id))
    sizes = get_sizes_list(product.sizes)
    return render_template_string(ORDER_HTML, product_name=product.name, product_id=product.id, sizes=sizes,
                                  messages=get_flashed_messages(with_categories=True))


