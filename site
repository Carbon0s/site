@app.route('/order', methods=['GET', 'POST'])
def make_order():
    if request.method == 'POST':
        try:
            product = Product.query.get_or_404(int(request.form['product_id']))
            if not product.available:
                flash('К сожалению, товар закончился.', 'danger')
                return redirect('/')

            krw = product.last_krw_price or 0
            price_rub, price_usd, real_rub, real_usd, profit = calculate_order_prices(krw)

            order = Order(
                name=request.form['name'], surname=request.form['surname'],
                phone=request.form['phone'], email=request.form.get('email'),
                address=request.form['address'], product_id=product.id,
                size=request.form['size'], comment=request.form.get('comment'),
                price_rub_at_order=price_rub, price_usd_at_order=price_usd,
                real_price_rub_at_order=real_rub, real_price_usd_at_order=real_usd, profit_rub=profit
            )
            db.session.add(order)
            db.session.commit()
            return redirect(url_for('thanks'))
        except Exception as e:
            db.session.rollback()
            flash(f'Ошибка: {str(e)}', 'danger')

    product_id = request.args.get('product_id')
    if not product_id: return redirect('/')
    product = Product.query.get_or_404(int(product_id))
    if not product.available:
        flash('Этот товар сейчас недоступен для заказа.', 'warning')
        return redirect('/')

    sizes = get_sizes_list(product.sizes)
    return render_template_string(ORDER_HTML, product_name=product.name, product_color=product.color,
                                  product_id=product.id, sizes=sizes)


