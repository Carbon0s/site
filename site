@app.route('/update_prices')
def update_prices():
    with app.app_context():
        products = Product.query.all()
        result = {}
        updated_in_this_request = 0

        for p in products:
            if not (p.price and "kream.co.kr" in p.price):
                result[p.id] = get_display_price(p)
                continue

            # Если цена уже есть и нормальная — не трогаем
            if p.last_krw_price and p.last_krw_price > 10000:
                result[p.id] = get_display_price(p)
                continue

            # Пробуем обновить только если ещё не загружена
            krw = parse_kream_price(p.price)
            if krw and krw > 10000:
                p.last_krw_price = krw
                p.markup_krw = round(krw * MARKUP)
                db.session.commit()
                print(f"✅ Успешно обновлена цена для товара {p.id}")
                updated_in_this_request += 1
                result[p.id] = get_display_price(p)
            else:
                result[p.id] = None  # всё ещё загружается

        db.session.commit()
        return jsonify(result)


def get_display_price(product):
    krw = getattr(product, 'last_krw_price', 0) or 0
    if krw < 10000:
        return None
    rub = round((krw / USD_TO_KRW * USD_TO_RUB * MARKUP) / 10) * 10
    usd = round(rub / USD_TO_RUB)
    return {"rub": int(rub), "usd": int(usd)}


# ================== ФОН (раз в 5 минут) ==================
def background_update_prices():
    while True:
        with app.app_context():
            products = Product.query.all()
            updated = 0
            for p in products:
                if p.price and "kream.co.kr" in p.price and (not p.last_krw_price or p.last_krw_price < 10000):
                    krw = parse_kream_price(p.price)
                    if krw and krw > 10000:
                        p.last_krw_price = krw
                        p.markup_krw = round(krw * MARKUP)
                        updated += 1
            if updated > 0:
                db.session.commit()
                print(f"✅ Фон: обновлено {updated} товаров")
        time.sleep(300)


