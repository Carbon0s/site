@app.route('/api/products_by_ids')
def api_products_by_ids():
    ids_str = request.args.get('ids', '')
    if not ids_str: return jsonify([])
    try:
        id_list = [int(x.strip()) for x in ids_str.split(',') if x.strip().isdigit()]
        products = Product.query.filter(Product.id.in_(id_list)).all()
        res = []
        for p in products:
            prices = get_display_price(p)
            res.append({
                'id': p.id, 'name': p.name, 'brand': p.brand, 'color': p.color,
                'image': p.image, 'available': p.available,
                'rub': prices['rub'] if prices else None,
                'usd': prices['usd'] if prices else None
            })
        return jsonify(res)
    except:
        return jsonify([])


