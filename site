USD_TO_KRW = 1483.0
USD_TO_RUB = 77.38
MARKUP = 1.65


def get_random_headers():
    ua = [
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/135.0.0.0 Safari/537.36",
        "Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:136.0) Gecko/20100101 Firefox/136.0",
    ]
    return {"User-Agent": random.choice(ua), "Referer": "https://kream.co.kr/"}


def update_exchange_rates():
    global USD_TO_KRW, USD_TO_RUB
    try:
        r = requests.get("https://api.exchangerate-api.com/v4/latest/USD", timeout=10)
        if r.status_code == 200:
            data = r.json()['rates']
            USD_TO_KRW = data.get('KRW', USD_TO_KRW)
            USD_TO_RUB = data.get('RUB', USD_TO_RUB)
            print(f"✅ Курс: 1 USD = {USD_TO_KRW:.0f} KRW | {USD_TO_RUB:.2f} RUB")
    except:
        pass


def parse_kream_price(url):
    if not url or "kream.co.kr/products/" not in url:
        return None
    print(f"→ Парсинг цены: {url}")
    for attempt in range(1, 4):
        try:
            time.sleep(random.uniform(1.2, 2.5))
            r = requests.get(url, headers=get_random_headers(), timeout=8)
            if r.status_code != 200:
                continue
            text = r.text.lower()
            candidates = []
            patterns = [r'"lowestprice"\s*:\s*(\d+)', r'"price"\s*:\s*(\d+)', r'"buyprice"\s*:\s*(\d+)']
            for pat in patterns:
                for m in re.findall(pat, text):
                    p = int(m)
                    if 10000 <= p <= 5000000:
                        candidates.append(p)
            for tag in re.findall(r'<h[1-3][^>]*>(.*?)</h[1-3]>', r.text, re.DOTALL | re.IGNORECASE):
                for m in re.findall(r'(\d{1,3}(?:[,\s]\d{3})*)\s*원', tag):
                    clean = re.sub(r'[^0-9]', '', m)
                    if clean:
                        p = int(clean)
                        if 10000 <= p <= 5000000:
                            candidates.append(p)
            if candidates:
                price = min(candidates)
                print(f"✅ ЦЕНА: {price:,} KRW")
                return price
        except:
            pass
    print(f"⚠️ Не удалось получить цену для {url}")
    return None


